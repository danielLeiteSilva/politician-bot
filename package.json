{
  "name": "politician-bot",
  "version": "2.0.0",
  "description": "Bot de WhatsApp que detecta e remove conteudo politico usando ChatGPT",
  "main": "dist/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "zod": "^4.3.6",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "joi": "^17.11.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.9",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@typescript-eslint/parser": "^6.9.0",
    "eslint": "^8.52.0",
    "eslint-plugin-security": "^1.7.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.0.2"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "security-check": "node scripts/security-check.js",
    "pre-commit": "npm run security-check && npm run lint && npm test",
    "prepare": "husky install"
  },
  "keywords": [
    "whatsapp",
    "bot",
    "chatgpt",
    "politica"
  ],
  "author": "Daniel Silva",
  "license": "ISC",
  "lint-staged": {
    "*.{ts,js}": [
      "npm run lint:fix",
      "npm run security-check"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm run security-check && npm test"
    }
  }
}